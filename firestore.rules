rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if the current user is a verified administrator
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'dan@shawsbutchers.net' && 
             request.auth.token.email_verified == true;
    }
    
    // Helper to validate product schema
    function isValidProduct(product) {
      return product.id is string && product.id.size() > 0 && product.id.size() <= 100 &&
             product.name is string && product.name.size() > 0 && product.name.size() <= 100 &&
             product.category is string && product.category in ['beef', 'lamb', 'pork', 'chicken', 'sausage', 'bacon', 'eggs', 'other', 'specials', 'seasonal', 'christmas'] &&
             product.price is number && product.price >= 0.0 &&
             product.unit is string && product.unit.size() <= 50 &&
             product.description is string && product.description.size() <= 1000 &&
             product.badge is string && product.badge.size() <= 50 &&
             product.available is bool &&
             product.soldOut is bool &&
             product.image is string && product.image.size() <= 1048576; // Max 1MB base64
    }

    // Helper to validate order schema
    function isValidOrder(order) {
      return order.id is string && order.id.size() > 0 && order.id.size() <= 50 &&
             order.date is string && order.date.size() <= 50 &&
             order.status == 'pending' &&
             order.total is number && order.total >= 0.0 &&
             order.customer is map &&
             order.customer.name is string && order.customer.name.size() > 0 && order.customer.name.size() <= 100 &&
             order.customer.phone is string && order.customer.phone.size() >= 5 && order.customer.phone.size() <= 30 &&
             order.customer.email is string && order.customer.email.size() <= 100 &&
             order.customer.address is string && order.customer.address.size() <= 200 &&
             order.customer.postcode is string && order.customer.postcode.size() <= 20 &&
             order.customer.collectionDate is string && order.customer.collectionDate.size() <= 50 &&
             order.customer.collectionTime is string && order.customer.collectionTime.size() <= 50 &&
             order.customer.notes is string && order.customer.notes.size() <= 1000 &&
             order.items is list && order.items.size() > 0 && order.items.size() <= 100;
    }

    // Helper to validate settings schema
    function isValidSettings(settings) {
      return settings.whatsappNumber is string && settings.whatsappNumber.size() <= 30 &&
             settings.googleSheetUrl is string && settings.googleSheetUrl.size() <= 1000;
    }

    // 1. Products: Storefront can read; only authenticated admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }
    
    // 2. Orders: Customers can submit (create) pending orders; only authenticated admins can read, update, or delete
    match /orders/{orderId} {
      allow create: if request.app != null && orderId == request.resource.data.id && isValidOrder(request.resource.data);
      allow read, delete: if isAdmin();
      allow update: if isAdmin() && request.resource.data.status in ['pending', 'confirmed', 'ready', 'collected'];
    }
    
    // 3. Settings: Storefront can read (e.g. for WhatsApp routing details); only authenticated admins can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }
  }
}
