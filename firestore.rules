rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Products: Storefront can read; only authenticated admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 2. Orders: Customers can submit (create); only authenticated admins can read, update, or delete
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // 3. Settings: Storefront can read (e.g. for WhatsApp routing details); only authenticated admins can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
